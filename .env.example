NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://nextmsg:nextmsg@localhost:5432/nextmsg?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-random-bytes
API_TOKEN_PEPPER=replace-with-a-separate-random-secret
PUBLIC_BASE_URL=http://localhost:4000
WEBHOOK_SIGNING_SECRET=replace-with-webhook-secret
MAX_SENDS_PER_MINUTE_PER_INSTANCE=20

# Optional ERPNext / Frappe bridge
ERPNEXT_URL=https://erp.example.com
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_BRIDGE_SECRET=replace-with-erpnext-bridge-secret
